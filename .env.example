# Copy to .env and edit.
# Docker Compose uses POSTGRES_* to create the database.
# The Go API connects using DATABASE_URL if set; otherwise it builds the URL from
# POSTGRES_USER + POSTGRES_PASSWORD + POSTGRES_DB + optional POSTGRES_HOST / POSTGRES_PORT
# (defaults: localhost:5432). That way POSTGRES_USER=ryan is enough without duplicating it in DATABASE_URL.
#
# If you *do* set DATABASE_URL, the user in the URL must match POSTGRES_USER or remove DATABASE_URL
# to use the auto-built URL.

POSTGRES_PASSWORD=changeme
POSTGRES_DB=weave
POSTGRES_USER=postgres
DATABASE_URL=postgres://postgres:changeme@localhost:5432/weave?sslmode=disable
WEAVE_MODE=persist

# Optional: omit DATABASE_URL and rely on POSTGRES_* only (same user for Compose + API):
# POSTGRES_USER=ryan
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=weave
# WEAVE_MODE=persist
