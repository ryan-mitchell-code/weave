# Repo-root .env (not committed). Docker Compose reads POSTGRES_*; the Go API uses DATABASE_URL only.
# Keep them aligned: same user, password, and database name.

POSTGRES_PASSWORD=changeme
POSTGRES_DB=weave
POSTGRES_USER=postgres
DATABASE_URL=postgres://postgres:changeme@localhost:5432/weave?sslmode=disable
WEAVE_MODE=persist
