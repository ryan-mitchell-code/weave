# Copy to .env and edit. POSTGRES_* are used by Docker Compose; DATABASE_URL is used by the Go API.
# The username in DATABASE_URL (after postgres://) MUST match POSTGRES_USER. The password MUST match POSTGRES_PASSWORD.

POSTGRES_PASSWORD=changeme
POSTGRES_DB=weave
POSTGRES_USER=postgres
DATABASE_URL=postgres://postgres:changeme@localhost:5432/weave?sslmode=disable
WEAVE_MODE=persist

# Example if your DB superuser is not "postgres":
# POSTGRES_USER=ryan
# DATABASE_URL=postgres://ryan:changeme@localhost:5432/weave?sslmode=disable
